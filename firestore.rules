// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: siteContent
// Document ID: main
// Fields:
//   - All fields from defaultSiteContent (logo, heroTitleStart, etc.)
//
// ===============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Site Content Matcher
    match /siteContent/{document=**} {
      // Allow read for everyone to display the site
      allow read: if true;
      
      // Allow write for everyone for now to fix permission issues
      allow write: if true;
    }
  }
}
